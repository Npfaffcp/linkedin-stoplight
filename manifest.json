{
  "manifest_version": 3,
  "name": "LinkedIn Stoplight",
  "version": "1.0.0",
  "description": "Track candidates you've already spoken to. Green = new, Red = already contacted.",
  "permissions": ["storage", "activeTab"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/green16.png",
      "48": "icons/green48.png",
      "128": "icons/green128.png"
    }
  },
  "icons": {
    "16": "icons/green16.png",
    "48": "icons/green48.png",
    "128": "icons/green128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/in/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
